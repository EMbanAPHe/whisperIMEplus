<?xml version="1.0" encoding="utf-8"?>
<!--
    D-pad: 4 solid arrow-heads pushed near the outer edges.
    No center section, no stems. Viewport 24x24, centre at 12,12.
    The arrows sit inside a faint circle to show the drag zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="36dp" android:height="36dp"
    android:viewportWidth="24" android:viewportHeight="24">

    <!-- Faint background circle — shows this is a drag zone -->
    <path android:strokeColor="#22FFFFFF" android:strokeWidth="0.6"
          android:fillColor="#00000000"
          android:pathData="M12,2 A10,10 0 1,0 12,22 A10,10 0 1,0 12,2 Z"/>

    <!-- Up arrow — near top edge -->
    <path android:fillColor="#CCFFFFFF"
          android:pathData="M12,2.5 L9,7.5 L11.2,7.5 L11.2,10.5 L12.8,10.5 L12.8,7.5 L15,7.5 Z"/>

    <!-- Down arrow — near bottom edge -->
    <path android:fillColor="#CCFFFFFF"
          android:pathData="M12,21.5 L15,16.5 L12.8,16.5 L12.8,13.5 L11.2,13.5 L11.2,16.5 L9,16.5 Z"/>

    <!-- Left arrow — near left edge -->
    <path android:fillColor="#CCFFFFFF"
          android:pathData="M2.5,12 L7.5,9 L7.5,11.2 L10.5,11.2 L10.5,12.8 L7.5,12.8 L7.5,15 Z"/>

    <!-- Right arrow — near right edge -->
    <path android:fillColor="#CCFFFFFF"
          android:pathData="M21.5,12 L16.5,15 L16.5,12.8 L13.5,12.8 L13.5,11.2 L16.5,11.2 L16.5,9 Z"/>

</vector>
