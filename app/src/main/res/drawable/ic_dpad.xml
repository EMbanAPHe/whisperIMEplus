<?xml version="1.0" encoding="utf-8"?>
<!--
    D-pad: 4 chevrons (> shape = two stroke lines meeting at a point).
    These ARE strokes, which Android vector drawables support fully.
    Each chevron is a V-shape open at the back, pointing outward.
    strokeWidth 3dp gives a bold, clear > appearance.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="36dp" android:height="36dp"
    android:viewportWidth="24" android:viewportHeight="24">

    <!-- Up chevron: ^ shape (two lines going up to a point) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#88FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M8,10 L12,5 L16,10"/>

    <!-- Down chevron: v shape -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#88FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M8,14 L12,19 L16,14"/>

    <!-- Left chevron: < shape -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#88FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M10,8 L5,12 L10,16"/>

    <!-- Right chevron: > shape -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#88FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M14,8 L19,12 L14,16"/>

</vector>
