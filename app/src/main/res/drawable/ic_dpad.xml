<?xml version="1.0" encoding="utf-8"?>
<!--
    D-pad: four filled triangular arrows (chevron/play-button style, like ">")
    pointing outward near the edges. Clear centre gap. Viewport 24x24.
    Colour: #88FFFFFF (soft white, not glaring).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="36dp" android:height="36dp"
    android:viewportWidth="24" android:viewportHeight="24">

    <!-- Up ▲: tip at y=2, base at y=8, base width 10, centred at x=12 -->
    <path android:fillColor="#88FFFFFF"
          android:pathData="M12,2 L7,8 L17,8 Z"/>

    <!-- Down ▼: tip at y=22, base at y=16, base width 10, centred at x=12 -->
    <path android:fillColor="#88FFFFFF"
          android:pathData="M12,22 L7,16 L17,16 Z"/>

    <!-- Left ◀: tip at x=2, base at x=8, base height 10, centred at y=12 -->
    <path android:fillColor="#88FFFFFF"
          android:pathData="M2,12 L8,7 L8,17 Z"/>

    <!-- Right ▶: tip at x=22, base at x=16, base height 10, centred at y=12 -->
    <path android:fillColor="#88FFFFFF"
          android:pathData="M22,12 L16,7 L16,17 Z"/>

</vector>
