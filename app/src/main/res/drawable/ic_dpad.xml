<?xml version="1.0" encoding="utf-8"?>
<!-- D-pad: 4 bold > chevron arrows pointing outward. No fill, just strokes. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="36dp" android:height="36dp"
    android:viewportWidth="24" android:viewportHeight="24">

    <!-- Up: > rotated 270° (pointing up), tip at top -->
    <path android:strokeColor="#99FFFFFF" android:strokeWidth="3.5"
          android:strokeLineCap="round" android:strokeLineJoin="round"
          android:fillColor="@android:color/transparent"
          android:pathData="M7,10 L12,5 L17,10"/>

    <!-- Down: > rotated 90° (pointing down) -->
    <path android:strokeColor="#99FFFFFF" android:strokeWidth="3.5"
          android:strokeLineCap="round" android:strokeLineJoin="round"
          android:fillColor="@android:color/transparent"
          android:pathData="M7,14 L12,19 L17,14"/>

    <!-- Left: < (pointing left) -->
    <path android:strokeColor="#99FFFFFF" android:strokeWidth="3.5"
          android:strokeLineCap="round" android:strokeLineJoin="round"
          android:fillColor="@android:color/transparent"
          android:pathData="M10,7 L5,12 L10,17"/>

    <!-- Right: > (pointing right) -->
    <path android:strokeColor="#99FFFFFF" android:strokeWidth="3.5"
          android:strokeLineCap="round" android:strokeLineJoin="round"
          android:fillColor="@android:color/transparent"
          android:pathData="M14,7 L19,12 L14,17"/>

</vector>
