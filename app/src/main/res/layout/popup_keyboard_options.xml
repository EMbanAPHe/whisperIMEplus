<?xml version="1.0" encoding="utf-8"?>
<!--
  Keyboard button long-press popup.
  Three options side by side:
    Left  — Toggle Streaming mode
    Center — Switch to previous keyboard (default, highlighted)
    Right  — Open Settings
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/popup_background"
    android:padding="6dp">

    <TextView
        android:id="@+id/popup_streaming"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="80dp"
        android:padding="10dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:text="Streaming\nOFF"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/rounded_button_tonal" />

    <Space android:layout_width="4dp" android:layout_height="match_parent" />

    <TextView
        android:id="@+id/popup_keyboard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="80dp"
        android:padding="10dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:text="⌨ Keyboard"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/popup_option_center" />

    <Space android:layout_width="4dp" android:layout_height="match_parent" />

    <TextView
        android:id="@+id/popup_settings"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="80dp"
        android:padding="10dp"
        android:gravity="center"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:text="⚙ Settings"
        android:clickable="true"
        android:focusable="true"
        android:background="@drawable/rounded_button_tonal" />

</LinearLayout>
