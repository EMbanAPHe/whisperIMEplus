<?xml version="1.0" encoding="utf-8"?>
<!--
    Whisper+ IME keyboard panel — v11
    ==================================
    Left column (42 %):
      Top toolbar (35 %): [Discard Audio | ⌨ Keyboard (long-press popup)] + [Cancel]
      Mic (65 %): large tap-to-toggle button

    Right column (58 %), 5 equal rows — 3-button grid throughout:
      Row 1: [Select All | Delete Unselected | Send ▶]
      Row 2: [Cut | Copy | Paste]
      Row 3: [↩ Undo | ↻ Redo]        (2 buttons, each 50 %)
      Row 4: [. Full Stop | ⌦ Fwd Del | ⌫ Backspace]
      Row 5: [─── Space (weight 2) ─── | ⏎ Enter]

    All text buttons: 12sp, normal weight, white — consistent throughout.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboardBg"
    android:fitsSystemWindows="true"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Thin progress bar at very top -->
    <ProgressBar
        android:id="@+id/processing_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="false"
        android:progressTint="@color/colorAccent"
        android:progressBackgroundTint="@color/buttonTonal"
        android:indeterminateTint="@color/colorAccent" />

    <!-- Error / status message — hidden by default -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:textSize="13sp"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone" />

    <!-- ═════ Main content — height set programmatically ═════ -->
    <LinearLayout
        android:id="@+id/layout_keyboard_content"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:orientation="horizontal"
        android:layout_marginTop="5dp">

        <!-- ─── LEFT COLUMN (42 %) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.42"
            android:orientation="vertical">

            <!-- Top toolbar (35 % of content height) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.35"
                android:orientation="horizontal">

                <!-- Discard + Keyboard stacked (40 % of toolbar width) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.40"
                    android:orientation="vertical">

                    <!-- Discard Audio — replaces Settings button -->
                    <TextView
                        android:id="@+id/btnDiscard"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/rounded_button_tonal"
                        android:text="@string/discard_audio"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:enabled="false"
                        android:alpha="0.4" />

                    <!-- Keyboard switch — long press for options popup -->
                    <ImageButton
                        android:id="@+id/btnKeyboard"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_button_tonal"
                        android:src="@drawable/ic_keyboard_36dp"
                        android:contentDescription="@string/exit_button"
                        android:scaleType="centerInside"
                        android:padding="4dp" />

                </LinearLayout>

                <Space android:layout_width="6dp" android:layout_height="match_parent" />

                <!-- Cancel Recognition (60 % of toolbar width) -->
                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.60"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/cancel_recognition"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:enabled="false"
                    android:alpha="0.4" />

            </LinearLayout>

            <!-- Mic button (65 % of content height) -->
            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.65"
                android:layout_marginTop="5dp"
                android:background="@drawable/rounded_button_tonal"
                android:src="@drawable/ic_mic_48dp"
                android:contentDescription="@string/record_button"
                android:scaleType="centerInside" />

        </LinearLayout>

        <Space android:layout_width="8dp" android:layout_height="match_parent" />

        <!-- ─── RIGHT COLUMN (58 %) — 5 equal rows, 3-button grid ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.58"
            android:orientation="vertical">

            <!-- Row 1: Select All | Delete Unselected | Send -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnSelectAll"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/select_all"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/delete_unselected"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_send_36dp"
                    android:contentDescription="@string/send"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Row 2: Cut | Copy | Paste -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCut"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/cut"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnCopy"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/copy"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btnPaste"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/paste"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Row 3: Undo | Redo (2 buttons, 50/50) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnUndo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_undo_36dp"
                    android:contentDescription="@string/undo"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btnRedo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_redo_36dp"
                    android:contentDescription="@string/redo"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Row 4: Full Stop | Forward Delete | Backspace -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <!-- Full Stop — long press shows punctuation popup -->
                <TextView
                    android:id="@+id/btnFullStop"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/full_stop"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

                <!-- Forward Delete -->
                <TextView
                    android:id="@+id/btnForwardDel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/forward_delete"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <!-- Backspace -->
                <ImageButton
                    android:id="@+id/btnDel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_keyboard_del_48dp"
                    android:contentDescription="@string/delete_button"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Row 5: Space (2/3) | Enter (1/3) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnSpace"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/space_bar"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnEnter"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_keyboard_return_48dp"
                    android:contentDescription="@string/return_button"
                    android:scaleType="centerInside" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
