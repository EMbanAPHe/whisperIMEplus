<?xml version="1.0" encoding="utf-8"?>
<!--
    Whisper+ IME keyboard panel — v3
    =================================
    Left column (60 %):
      Top toolbar (35 %): [⚙ Settings | ⌨ Keyboard] stacked  +  [Cancel — text]
      Mic (65 %): large tap-to-toggle button

    Right column (40 %), 4 equal rows:
      Row 1: [Clear Unselected — text] [Send ▶]   — equal width
      Row 2: [↩ Undo]                 [↻ Redo]    — equal width
      Row 3: [⌫ Backspace]                         — full width
      Row 4: [Space — text]           [⏎ Return]  — equal width

    Height set programmatically in onCreateInputView() to 33 % of display
    height (portrait) / 45 % (landscape).  fitsSystemWindows on root handles
    the navigation-bar inset automatically.

    Button states:
      Mic idle     → rounded_button_tonal  (subdued)
      Mic active   → rounded_button_background (bright accent)
    All secondary buttons → rounded_button_tonal
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboardBg"
    android:fitsSystemWindows="true"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Thin progress bar at very top -->
    <ProgressBar
        android:id="@+id/processing_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="false"
        android:progressTint="@color/colorAccent"
        android:progressBackgroundTint="@color/buttonTonal"
        android:indeterminateTint="@color/colorAccent" />

    <!-- Error / permission message — hidden by default -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:textSize="13sp"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone" />

    <!-- ═════ Main content — height set programmatically ═════ -->
    <LinearLayout
        android:id="@+id/layout_keyboard_content"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:orientation="horizontal"
        android:layout_marginTop="5dp">

        <!-- ─── LEFT COLUMN (60 %) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:orientation="vertical">

            <!-- Top toolbar (35 % of content height) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.35"
                android:orientation="horizontal">

                <!-- Settings + Keyboard stacked (35 % of toolbar width) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.35"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnSettings"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/rounded_button_tonal"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="@string/settings"
                        android:scaleType="centerInside"
                        android:padding="4dp" />

                    <ImageButton
                        android:id="@+id/btnKeyboard"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_button_tonal"
                        android:src="@drawable/ic_keyboard_36dp"
                        android:contentDescription="@string/exit_button"
                        android:scaleType="centerInside"
                        android:padding="4dp" />

                </LinearLayout>

                <Space android:layout_width="6dp" android:layout_height="match_parent" />

                <!-- Cancel — text label (65 % of toolbar width) -->
                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.65"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/cancel_recognition"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:enabled="false"
                    android:alpha="0.4" />

            </LinearLayout>

            <!-- Mic button (65 % of content height) — idle=tonal, active=bright -->
            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.65"
                android:layout_marginTop="5dp"
                android:background="@drawable/rounded_button_tonal"
                android:src="@drawable/ic_mic_48dp"
                android:contentDescription="@string/record_button"
                android:scaleType="centerInside" />

        </LinearLayout>

        <Space android:layout_width="8dp" android:layout_height="match_parent" />

        <!-- ─── RIGHT COLUMN (40 %) — 4 equal rows ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4"
            android:orientation="vertical">

            <!-- Row 1: [Clear Unselected] [Send] — equal width -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/delete_unselected"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_send_36dp"
                    android:contentDescription="@string/send"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Row 2: [Undo] [Redo] — equal width -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnUndo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_undo_36dp"
                    android:contentDescription="@string/undo"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btnRedo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_redo_36dp"
                    android:contentDescription="@string/redo"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Row 3: [Backspace] — full width -->
            <ImageButton
                android:id="@+id/btnDel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:background="@drawable/rounded_button_tonal"
                android:src="@drawable/ic_keyboard_del_48dp"
                android:contentDescription="@string/delete_button"
                android:scaleType="centerInside" />

            <!-- Row 4: [Space] [Return] — equal width -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnSpace"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/space_bar"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnEnter"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_keyboard_return_48dp"
                    android:contentDescription="@string/return_button"
                    android:scaleType="centerInside" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
