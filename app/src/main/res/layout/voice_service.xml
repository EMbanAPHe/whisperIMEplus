<?xml version="1.0" encoding="utf-8"?>
<!--
    Whisper+ IME keyboard panel — v11b
    =====================================
    Left column (54% — 90% of original 60%):
      Toolbar: [Discard Audio | ⌨ Keyboard (long-press popup)] + [Cancel Recognition]
      Mic: large button

    Right column (46%), 5 equal rows:
      Row 1: [SelectAll icon | Del Unselected | Send icon]
      Row 2: [Cut icon | Copy icon | Paste icon]
      Row 3: [.,?! popup-toggle | Undo icon | Redo icon]
      Row 4: [Fwd Del icon (w=1) | Backspace icon (w=2)]
      Row 5: [Space (w=2) | Enter (w=1)]
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboardBg"
    android:fitsSystemWindows="true"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/processing_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="false"
        android:progressTint="@color/colorAccent"
        android:progressBackgroundTint="@color/buttonTonal"
        android:indeterminateTint="@color/colorAccent" />

    <!-- Status / error message -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="2dp"
        android:textSize="13sp"
        android:textColor="@android:color/holo_red_dark"
        android:visibility="gone" />

    <!-- Main content — height set programmatically -->
    <LinearLayout
        android:id="@+id/layout_keyboard_content"
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:orientation="horizontal"
        android:layout_marginTop="5dp">

        <!-- ─── LEFT COLUMN (54%) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.54"
            android:orientation="vertical">

            <!-- Toolbar (35% of height) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.35"
                android:orientation="horizontal">

                <!-- Discard + Keyboard stacked (40% of toolbar) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.40"
                    android:orientation="vertical">

                    <ImageButton
                        android:id="@+id/btnKeyboard"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:layout_marginBottom="3dp"
                        android:background="@drawable/rounded_button_tonal"
                        android:src="@drawable/ic_keyboard_36dp"
                        android:contentDescription="@string/exit_button"
                        android:scaleType="centerInside"
                        android:padding="4dp" />

                    <TextView
                        android:id="@+id/btnDiscard"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/rounded_button_tonal"
                        android:text="@string/discard_audio"
                        android:gravity="center"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:enabled="false"
                        android:alpha="0.4" />

                </LinearLayout>

                <Space android:layout_width="6dp" android:layout_height="match_parent" />

                <!-- Cancel Recognition (60% of toolbar) -->
                <TextView
                    android:id="@+id/btnCancel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="0.60"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/cancel_recognition"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:enabled="false"
                    android:alpha="0.4" />

            </LinearLayout>

            <!-- Mic button (65% of height) -->
            <ImageButton
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.65"
                android:layout_marginTop="5dp"
                android:background="@drawable/rounded_button_tonal"
                android:src="@drawable/ic_mic_48dp"
                android:contentDescription="@string/record_button"
                android:scaleType="centerInside" />

        </LinearLayout>

        <Space android:layout_width="8dp" android:layout_height="match_parent" />

        <!-- ─── RIGHT COLUMN (46%) ─── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.46"
            android:orientation="vertical">

            <!-- Row 1: Select All icon | Delete Unselected | Send icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.17"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnSelectAll"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_select_all"
                    android:contentDescription="@string/select_all"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

                <TextView
                    android:id="@+id/btnClear"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/delete_unselected"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnSend"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_send_36dp"
                    android:contentDescription="@string/send"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

            </LinearLayout>

            <!-- Row 2: Cut icon | Copy icon | Paste icon -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.17"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnCut"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_cut"
                    android:contentDescription="@string/cut"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

                <ImageButton
                    android:id="@+id/btnCopy"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_copy"
                    android:contentDescription="@string/copy"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

                <ImageButton
                    android:id="@+id/btnPaste"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_paste"
                    android:contentDescription="@string/paste"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

            </LinearLayout>

            <!-- Row 3: .,?! popup toggle | Undo | Redo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.17"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <!-- Full stop / punctuation popup toggle — styled like mode-switch key -->
                <TextView
                    android:id="@+id/btnFullStop"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/full_stop_toggle"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnUndo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_undo_36dp"
                    android:contentDescription="@string/undo"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

                <ImageButton
                    android:id="@+id/btnRedo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_redo_36dp"
                    android:contentDescription="@string/redo"
                    android:scaleType="centerInside"
                    android:padding="9dp" />

            </LinearLayout>

            <!-- Row 4: Forward Delete (w=1) | Backspace (w=2) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.30"
                android:layout_marginBottom="4dp"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/btnForwardDel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_forward_del"
                    android:contentDescription="@string/forward_delete"
                    android:scaleType="centerInside" />

                <ImageButton
                    android:id="@+id/btnDel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_keyboard_del_48dp"
                    android:contentDescription="@string/delete_button"
                    android:scaleType="centerInside" />

            </LinearLayout>

            <!-- Row 5: Space (w=2) | Enter (w=1) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="0.19"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnSpace"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/rounded_button_tonal"
                    android:text="@string/space_bar"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <ImageButton
                    android:id="@+id/btnEnter"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_tonal"
                    android:src="@drawable/ic_keyboard_return_48dp"
                    android:contentDescription="@string/return_button"
                    android:scaleType="centerInside" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
